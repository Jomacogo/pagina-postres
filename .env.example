# Número de WhatsApp del negocio (sin espacios, con código de país)
VITE_WHATSAPP_TELEFONO=TU_NUMERO_AQUI

# Mensaje predefinido que se envía al abrir WhatsApp
VITE_WHATSAPP_MENSAJE=Hola, me gustaría más información sobre tus productos
